programa {
  funcao inicio() {

    real renda, nota
    

    escreva("Qual foi sua nota?")
    leia(nota)
    escreva("Qual sua renda mensal?")
    leia(renda)

    se ((nota >= 8) e (renda <= 2000)){
      escreva("PARABENS VOCÊ GANHOU UMA BOLSA DE ESTUDO")
    }
      senao{
        escreva("voce nao ganhou nenhuma bolsa")
      }
    }
   }
  
