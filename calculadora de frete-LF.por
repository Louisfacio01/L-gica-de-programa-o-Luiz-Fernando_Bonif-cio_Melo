programa {
  funcao inicio() {
      cadeia KM

        escreva(" Qual a distancia em KM?")
        leia(KM)

          se (KM <= 50){
            escreva("frete gratis")}
            senao se ((KM >= 100) e (KM <= 199)){
              escreva("Frete == 17,97 reais")}
              senao se ((KM >= 200) e (KM <= 299)){
                escreva("frete == 27,97")
              }
              }
          }